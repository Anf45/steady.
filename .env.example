# Firebase Web App API key
VITE_FIREBASE_API_KEY=

# Firebase Auth domain, usually something like your-project.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN=

# Firebase project ID from your Firebase project settings
VITE_FIREBASE_PROJECT_ID=

# Firebase Storage bucket used for files and uploads
VITE_FIREBASE_STORAGE_BUCKET=

# Firebase Cloud Messaging sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Firebase app ID for this web app
VITE_FIREBASE_APP_ID=
